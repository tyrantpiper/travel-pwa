ssName=\"inline-block border border-slate-300 rounded px-1 text-[10px] font-bold mx-1\">Get API key</span> ?пүҗ??оҪұr\n                                    </div>\r\n                                </div>\r\n\r\n                                {/* з”Үд»ҝ? 3 (йқҪж јиҝӨ?? */}\r\n                                <div className=\"flex gap-3\">\r\n                                    <div className=\"w-5 h-5 rounded-full bg-slate-200 flex items-center justify-center text-slate-600 font-bold shrink-0\">3</div>\r\n                                    <div>\r\n                                        жҡәоөҘ? <b>Create API key</b> ?пҗ§?еҡ—п—ҫојҺ?пӢ«жҙөйҠқВҖ?п•ЎојҺ??<b>&quot;Create API key in new project&quot;</b>еҡ—п—Ҫ?йӢҶиіЎоҫ–йҠқ?<code>AIza...</code> ?п•Ўо№Ұ?п„‘иӘЁиқЈжҪ”и’ӮйһҺжҫҶоҜӯйҠқп“ҒоЎҗ?оҪұr\n                                    </div>\r\n                                </div>\r\n\r\n                                <div className=\"bg-amber-50 text-amber-700 p-2 rounded border border-amber-100 flex items-start gap-2 mt-2\">\r\n                                    <AlertCircle className=\"w-4 h-4 shrink-0 mt-0.5\" />\r\n                                    <span>?о©”оҰҖж‘°п—әп…І?пҡҡзҘҘ??(Free Tier)еҡ—п—»??дәҷоҸ»??1,500 з”ҲвҲҙ??п•ңзҠ–йӣҝиј»оң…иқ¬иіңйЈӯ?пҗ§???/span>\r\n                                </div>\r\n\r\n                            </AccordionContent>\r\n                        </AccordionItem>\r\n                    </Accordion>\r\n                </div>\r\n\r\n                <DialogFooter className=\"flex flex-row justify-between sm:justify-between gap-2\">\r\n                    <Button variant=\"outline\" onClick={handleClear} className=\"text-slate-400 hover:text-red-500\">\r\n                        <Eraser className=\"w-4 h-4 mr-2\" /> зҡңпҶіоЁ’\r\n                    </Button>\r\n                    <Button onClick={handleSave} className=\"bg-slate-900 text-white hover:bg-slate-800 flex-1 sm:flex-none\">\r\n                        <Key className=\"w-4 h-4 mr-2\" /> ?и„Ј?й–®еү–?\r\n                    </Button>\r\n                </DialogFooter>\r\n            </DialogContent>\r\n        </Dialog>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Ryan Su\\ryan-travel-app\\frontend\\components\\FullscreenMapModal.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Ryan Su\\ryan-travel-app\\frontend\\components\\POIDetailDrawer.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Ryan Su\\ryan-travel-app\\frontend\\components\\bottom-nav.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Ryan Su\\ryan-travel-app\\frontend\\components\\chat-widget.tsx","messages":[],"suppressedMessages":[{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":587,"column":37,"nodeType":"JSXOpeningElement","endLine":587,"endColumn":138,"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Ryan Su\\ryan-travel-app\\frontend\\components\\chat\\POIPreviewCard.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Ryan Su\\ryan-travel-app\\frontend\\components\\chat\\SourceCitation.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Ryan Su\\ryan-travel-app\\frontend\\components\\chat\\ThinkingIndicator.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Ryan Su\\ryan-travel-app\\frontend\\components\\day-map.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'markers'. Either include it or remove the dependency array.","line":182,"column":8,"nodeType":"ArrayExpression","endLine":182,"endColumn":36,"suggestions":[{"desc":"Update the dependencies array to be: [markers, markersKey, mode, optimize]","fix":{"range":[6020,6048],"text":"[markers, markersKey, mode, optimize]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\"\r\n\r\nimport { useEffect, useState, useRef, useCallback } from \"react\"\r\nimport Map, { Marker, Popup, Source, Layer, NavigationControl, AttributionControl } from \"react-map-gl/maplibre\"\r\nimport type { MapRef, LngLatBoundsLike } from \"react-map-gl/maplibre\"\r\nimport \"maplibre-gl/dist/maplibre-gl.css\"\r\nimport { Bus, Car, Footprints, Satellite, Map as MapIcon, Search, X, Loader2, MapPin, Clock, Crosshair, Trash } from \"lucide-react\"\r\nimport { MAP_STYLES } from \"@/lib/constants\"\r\nimport { Input } from \"@/components/ui/input\"\r\nimport { geocodeApi } from \"@/lib/api\"\r\nimport { motion, AnimatePresence } from \"framer-motion\"\r\nimport POIDetailDrawer, { POIBasicData } from \"@/components/POIDetailDrawer\"\r\n\r\n// Activity жҶҝоөӨ?ж‘°о«Іе„”\r\ninterface Activity {\r\n    id?: string\r\n    lat?: number\r\n    lng?: number\r\n    place?: string\r\n    time?: string\r\n    desc?: string\r\n    category?: string\r\n}\r\n\r\n// Marker ж•№пҶі??пҗЈжјЈз’…о§¬r\ninterface MarkerData {\r\n    id?: string\r\n    lat: number\r\n    lng: number\r\n    place?: string\r\n    time?: string\r\n    desc?: string\r\n    category?: string\r\n    number: number\r\n}\r\n\r\n// й қиҲҗ?жҶҝоҗҙпҸ°ж’ пҡҷп…ұ\r\nconst routeColors = {\r\n    walk: \"#22c55e\",    // иқ¬оәЎпҸ° - з”ҮдәҘ?\r\n    drive: \"#3b82f6\",   // ?пҡҡпҸ° - ?п• ?\r\n    transit: \"#f59e0b\", // з’ҲоҰ№пҸ° - жҶӯжҠ’о°ғ?п• ж’“\r\n}\r\n\r\n// API ?з®Ү?й қиҮ¬?\r\nconst API_BASE = process.env.NEXT_PUBLIC_API_URL || \"http://localhost:8000\"\r\n\r\n// ?о°Ә?иқҜо“Ҹ?жҶҝоөӨ?\r\ninterface SearchResult {\r\n    lat: number\r\n    lng: number\r\n    name: string\r\n    address?: string\r\n    type?: string\r\n}\r\n\r\n// ?о°Ә?з”Үз‘•оҸҫ Hook\r\nconst HISTORY_KEY = \"map_search_history\"\r\nfunction useSearchHistory() {\r\n    const [history, setHistory] = useState<SearchResult[]>(() => {\r\n        if (typeof window === 'undefined') return []\r\n        try {\r\n            const stored = localStorage.getItem(HISTORY_KEY)\r\n            return stored ? JSON.parse(stored) : []\r\n        } catch { return [] }\r\n    })\r\n\r\n    const addToHistory = useCallback((item: SearchResult) => {\r\n        setHistory(prev => {\r\n            const updated = [item, ...prev.filter(h => h.name !== item.name)].slice(0, 5)\r\n            localStorage.setItem(HISTORY_KEY, JSON.stringify(updated))\r\n            return updated\r\n        })\r\n    }, [])\r\n\r\n    // ?? зҡңпҶіоЁ’з”Үз‘•оҸҫй–®оҰә?\r\n    const clearHistory = useCallback(() => {\r\n        setHistory([])\r\n        localStorage.removeItem(HISTORY_KEY)\r\n    }, [])\r\n\r\n    return { history, addToHistory, clearHistory }\r\n}\r\n\r\n// й қиҲҗ?й–¬оҗұ? Hook (йӣҝиј»оң…ж•әп—јеһў /api/route йҡһ??)\r\nfunction useRoute(markersKey: string, markers: MarkerData[], mode: string, optimize: boolean = false) {\r\n    const [route, setRoute] = useState<GeoJSON.Feature | null>(null)\r\n    const [routeInfo, setRouteInfo] = useState<{ distance: string; duration: string; source?: string } | null>(null)\r\n    const [loading, setLoading] = useState(false)\r\n\r\n    useEffect(() => {\r\n        if (markers.length < 2) {\r\n            setRoute(null)\r\n            setRouteInfo(null)\r\n            return\r\n        }\r\n\r\n        const fetchRoute = async () => {\r\n            setLoading(true)\r\n\r\n            // ?оЎј??пҗӨ? markers\r\n            const stopsPayload = markers.map(m => ({ lat: m.lat, lng: m.lng, name: m.place }))\r\n\r\n            // ж’ҪоӨң?ж‘Ёжүі??пҗӨ??еҗӯr\n            const validStops = stopsPayload.filter(s =>\r\n                s.lat && s.lng &&\r\n                typeof s.lat === 'number' && typeof s.lng === 'number' &&\r\n                s.lat !== 0 && s.lng !== 0\r\n            )\r\n\r\n            if (validStops.length < 2) {\r\n                console.warn(\"?оәЁ? [Route Debug] ж’ о•¬оЎ“ 2 ?п•һ??пҺҶжјЈз’…о©қ?й қе–І?й қиҲҗ?й–®пҺҲ?\")\r\n                setRoute(null)\r\n                setRouteInfo(null)\r\n                setLoading(false)\r\n                return\r\n            }\r\n\r\n            // ?? з‘јпјёи‘«й қе…ё??оё„жҘқиқә?(й қе…ё?/й қеҶҪзөІ) - иқәиҮ¬жјІж’Ңж Ә???5 ж‘ЁиҘҝ??з®„жҘҠ?ВҖ?о¶ҡr\n            const lats = validStops.map(s => s.lat)\r\n            const latSpan = Math.max(...lats) - Math.min(...lats)\r\n\r\n            if (latSpan > 5) {\r\n                console.warn(\"?оәЁ? [Route Debug] й қе…ё??оё„жҘқиқә?(иқәиҮ¬жјІж’Ң?\", latSpan.toFixed(2), \"ж‘Ё?еҡ—п—№иқҷ?еҮҪоӯңиқәо«ҙВҖ?оҚ”\")\r\n                // ?? иқңиҠҫЛҠ?жёЎ???оҚ”?ВҖ?пҗ§? (?о®Ҹ?йҠөеҮҪе…§?оөҘйғҠйҠөп—ҪжҘқиқә?\r\n                const straightLineRoute: GeoJSON.Feature = {\r\n                    type: \"Feature\",\r\n                    properties: {},\r\n                    geometry: {\r\n                        type: \"LineString\",\r\n                        coordinates: validStops.map(s => [s.lng, s.lat])\r\n                    }\r\n                }\r\n                setRoute(straightLineRoute)\r\n                setRouteInfo({\r\n                    distance: \"й қе…ё??о¶ҡ",\r\n                    duration: \"?жҖЁпҚӢ?иӢ’",\r\n                    source: \"straight-line\"\r\n                })\r\n                setLoading(false)\r\n                return\r\n            }\r\n\r\n            try {\r\n                const res = await fetch(`${API_BASE}/api/route`, {\r\n                    method: \"POST\",\r\n                    headers: { \"Content-Type\": \"application/json\" },\r\n                    body: JSON.stringify({\r\n                        stops: validStops,  // ?иҠёоҫҰ?ојј??пҺҶжјЈз’…о§¬r\n                        mode,\r\n                        optimize\r\n                    })\r\n                })\r\n\r\n                if (!res.ok) {\r\n                    const errorText = await res.text()\r\n                    console.error(\"??[Route Debug] API Error:\", res.status, errorText)\r\n                    throw new Error(`Route API failed: ${res.status}`)\r\n                }\r\n\r\n                const data = await res.json()\r\n\r\n                if (data.route) {\r\n                    setRoute(data.route)\r\n                    setRouteInfo({\r\n                        distance: data.distance,\r\n                        duration: data.duration,\r\n                        source: data.source\r\n                    })\r\n                }\r\n            } catch (e) {\r\n                console.error(\"??[Route Debug] Fetch error:\", e)\r\n                // ?пҶі?ж‘°пҗЈп…Іеҡ—о«ұ??ж–№жҘқиқәо«Ҝ?йҠқпҡ—жҸҙзһҸиұ№r\n                setRoute(null)\r\n                setRouteInfo(null)\r\n            } finally {\r\n                setLoading(false)\r\n            }\r\n        }\r\n\r\n        fetchRoute()\r\n        // Note: Only use markersKey (stable string) as dependency, NOT markers array (recreated every render)\r\n    }, [markersKey, mode, optimize])\r\n\r\n    return { route, routeInfo, loading }\r\n}\r\n\r\ninterface DayMapProps {\r\n    activities: Activity[]\r\n    onAddPOI?: (poi: POIBasicData, time: string, notes?: string) => void\r\n    dailyLoc?: { lat: number; lng: number; name?: string }  // ?? ?е—ҶоЈҷ?о“‘иә«йҠқеү–?жҡәоіҪr\n    tripTitle?: string  // ?? йҠөп—ј?з’…о©—?еҡ—пҺҲоң…?жҪӯоЁЁ?иіЈ?ж’ п•§?\r\n}\r\n\r\nexport default function DayMap({ activities, onAddPOI, dailyLoc, tripTitle }: DayMapProps) {\r\n    const mapRef = useRef<MapRef>(null)\r\n    const [mode, setMode] = useState<'walk' | 'drive' | 'transit'>('walk')\r\n    const [popupInfo, setPopupInfo] = useState<MarkerData | null>(null)\r\n    const [mapLoaded, setMapLoaded] = useState(false)\r\n\r\n    // ?? Terra-Cognita: ж‘Ёоҹҹ?з’…вҲӘ? (з’…о©”?/йҠөо®Һ?)\r\n    const [mapMode, setMapMode] = useState<'standard' | 'satellite'>('standard')\r\n\r\n    // ?? POI Detail Drawer ?ВҖ?п“¶r\n    // ?? POI Detail Drawer ?ВҖ?п“¶r\n    const [poiDrawerOpen, setPoiDrawerOpen] = useState(false)\r\n    const [selectedPOI, setSelectedPOI] = useState<POIBasicData | null>(null)\r\n\r\n    // ?? ?о°Ә??ВҖ?п“¶r\n    const [isSearchOpen, setIsSearchOpen] = useState(false)\r\n    const [isSearchMinimized, setIsSearchMinimized] = useState(false)  // ?? ?ВҖж’ оҗұ??ВҖ?п“¶r\n    const [query, setQuery] = useState(\"\")\r\n    const [results, setResults] = useState<SearchResult[]>([])\r\n    const [isTyping, setIsTyping] = useState(false)     // ?? й ӣи©Ёп…ҜйҠқе“Ё?debounce ?оё…?еҡ—пҺјr\n    const [isSearching, setIsSearching] = useState(false)\r\n    const { history, addToHistory, clearHistory } = useSearchHistory()\r\n    const inputRef = useRef<HTMLInputElement>(null)\r\n\r\n    // ?? й ӣи©Ёп…ҜйңҲп“Ғоӯң?оҹЎ?еҡ—пҺҲ??е–і?ж“–п•§?\r\n    const handleQueryChange = (e: React.ChangeEvent<HTMLInputElement>) => {\r\n        const value = e.target.value\r\n        setQuery(value)\r\n        if (value.length >= 2) {\r\n            setIsTyping(true)\r\n        } else {\r\n            setIsTyping(false)\r\n            setResults([])\r\n        }\r\n    }\r\n\r\n    // ?? ?иҠё?иқўжӢҷ?йӣҝпҡ—???(?оЎ»иӘЁ??bug ??GeolocateControl)\r\n    const [userLocation, setUserLocation] = useState<{ lat: number; lng: number } | null>(null)\r\n    const [isLocating, setIsLocating] = useState(false)\r\n\r\n    // ?? ?о°Ә?иқҜо“Ҹ?з’…о©–?еҡ—пҺҲ??и„Јд№Ӣ?еүқ?еҡ—пҺјr\n    const [searchResultMarker, setSearchResultMarker] = useState<{ lat: number; lng: number; name: string } | null>(null)\r\n\r\n\r\n    const handleLocateMe = () => {\r\n        if (!(\"geolocation\" in navigator)) {\r\n            alert(\"?еҮҪ??оҗҙжұ—?е…¶??иҲҖоҗҖж‘°о«Ҝ??оё„пҒҚ\")\r\n            return\r\n        }\r\n        setIsLocating(true)\r\n        navigator.geolocation.getCurrentPosition(\r\n            (position) => {\r\n                const { latitude, longitude } = position.coords\r\n                setUserLocation({ lat: latitude, lng: longitude })\r\n                setIsLocating(false)\r\n                // жҶҢо®ҚпҚ‘?еҶҪпҚ—йӣҝпҡҷи”ӯ\r\n                if (mapRef.current) {\r\n                    mapRef.current.flyTo({\r\n                        center: [longitude, latitude],\r\n                        zoom: 15,\r\n                        duration: 2000\r\n                    })\r\n                }\r\n            },\r\n            (error) => {\r\n                setIsLocating(false)\r\n                console.error(\"Geolocation error:\", error)\r\n                if (error.code === error.PERMISSION_DENIED) {\r\n                    alert(\"ж‘°о«Ҝ?з”Ҳп“„?йӢЎжҖҘ?иқҜоҹ©?йҡўп•қ?й–®жўҒВҖоҗҙжұ—?еҮҪпҷӨ?оЎҪоҫӣ?п„‘?иқөеЁү")\r\n                } else {\r\n                    alert(\"?вҠҘ??и„Ј?йӣҝпҡҷи”ӯ: \" + error.message)\r\n                }\r\n            },\r\n            { enableHighAccuracy: true, timeout: 30000, maximumAge: 0 }\r\n        )\r\n    }\r\n\r\n\r\n    // Debounced ?о°Ә?\r\n    useEffect(() => {\r\n        if (!isSearchOpen || query.length < 2) {\r\n            setResults([])\r\n            setIsTyping(false)\r\n            return\r\n        }\r\n\r\n        const currentQuery = query  // ?? ж•№жҖҺп…ұ?и„«иҝ«иқЎе—Ҷ?\r\n\r\n        const timer = setTimeout(async () => {\r\n            setIsTyping(false)    // debounce иқҜо“Ҹ?\r\n            setIsSearching(true)\r\n            setResults([])  // Anti-flicker: clear old results before new search\r\n            try {\r\n                const center = mapRef.current?.getCenter()\r\n                const data = await geocodeApi.search({\r\n                    query: currentQuery,\r\n                    limit: 5,\r\n                    tripTitle,\r\n                    lat: center?.lat,\r\n                    lng: center?.lng\r\n                })\r\n                // ?? ?иҠёоҜӯ query йҡһпҡҷпғЈ?еҜҘ??оҝҷоӯң?иұ№r\n                if (currentQuery === query) {\r\n                    setResults(data.results || [])\r\n                }\r\n            } catch {\r\n                if (currentQuery === query) {\r\n                    setResults([])\r\n                }\r\n            } finally {\r\n                setIsSearching(false)\r\n            }\r\n        }, 300)\r\n\r\n        return () => clearTimeout(timer)\r\n    }, [query, isSearchOpen, tripTitle])\r\n\r\n    // ?иҠё? focus\r\n    useEffect(() => {\r\n        if (isSearchOpen && inputRef.current) {\r\n            setTimeout(() => inputRef.current?.focus(), 100)\r\n        }\r\n    }, [isSearchOpen])\r\n\r\n    // жҶҢо®ҚпҚ‘?пӢ©?йӣҝпҡҷи”ӯ\r\n    const flyTo = useCallback((result: SearchResult) => {\r\n        console.log(\"?пҺҗ? FlyTo triggered:\", result)\r\n        addToHistory(result)\r\n        setQuery(result.name)\r\n        setIsSearchOpen(false)\r\n\r\n        if (!mapRef.current) {\r\n            console.error(\"??Map ref is null\")\r\n            return\r\n        }\r\n\r\n        const lng = Number(result.lng)\r\n        const lat = Number(result.lat)\r\n\r\n        if (isNaN(lng) || isNaN(lat)) {\r\n            console.error(\"??Invalid coordinates:\", result)\r\n            return\r\n        }\r\n\r\n        mapRef.current.flyTo({\r\n            center: [lng, lat],\r\n            zoom: 16,\r\n            duration: 1500\r\n        })\r\n\r\n        // ?? й–®еү”и”ӯ?о°Ә?иқҜо“Ҹ?з’…о©–?еҡ—пҺҲ??и„Јд№Ӣ?еүқ?еҡ—пҺјr\n        setSearchResultMarker({ lat, lng, name: result.name })\r\n\r\n        // ж’ұз®Ү? POI йҠқйҳЎ???Drawer\r\n        setSelectedPOI({\r\n            name: result.name,\r\n            type: result.type || \"place\",\r\n            lat: result.lat,\r\n            lng: result.lng,\r\n            address: result.address\r\n        })\r\n        setPoiDrawerOpen(true)\r\n    }, [addToHistory])\r\n\r\n    // ?оҺ•и•Ә?з®ё?ж‘Ёжүі??п„’оҜөжҡәоіҪr\n    const markers = activities\r\n        .filter((a): a is Activity & { lat: number; lng: number } =>\r\n            typeof a.lat === 'number' && typeof a.lng === 'number'\r\n        )\r\n        .map((a, index) => ({\r\n            ...a,\r\n            number: index + 1\r\n        })) as MarkerData[]\r\n\r\n    const markersKey = markers.map(m => `${m.lat},${m.lng}`).join('|')\r\n    const { route, routeInfo, loading } = useRoute(markersKey, markers, mode)\r\n\r\n    // ?? Terra-Cognita: ?пӢӘ??оЎјжғң?иҲӘ??еҗӯr\n    const updateLayerVisibility = useCallback((isSatellite: boolean) => {\r\n        const map = mapRef.current?.getMap()\r\n        if (!map || !map.isStyleLoaded()) return\r\n\r\n        const layers = map.getStyle()?.layers || []\r\n\r\n        layers.forEach(layer => {\r\n            const layerId = layer.id.toLowerCase()\r\n\r\n            // йҠөо®Һ?з’…вҲӘ?еҡ—о«ҙоӘј?оҗҙ??иҲ«??оЎјжғң\r\n            if (MAP_STYLES.LAYERS_HIDE_ON_SATELLITE.some(hide => layerId.includes(hide))) {\r\n                map.setLayoutProperty(layer.id, 'visibility', isSatellite ? 'none' : 'visible')\r\n            }\r\n\r\n            // йҠөо®Һ?з’…вҲӘ?еҡ—о«ізҹҪ?ж№§?й қиҲ«ВҖоҗІ?ж‘Ёеҗ’r\n            if (MAP_STYLES.LAYERS_TRANSPARENT_ON_SATELLITE.some(road => layerId.includes(road))) {\r\n                if (layer.type === 'line') {\r\n                    try {\r\n                        map.setPaintProperty(\r\n                            layer.id,\r\n                            'line-opacity',\r\n                            isSatellite ? MAP_STYLES.ROAD_OPACITY_ON_SATELLITE : 1\r\n                        )\r\n                    } catch {\r\n                        // ?о“Қ??оЎјжғң?иҲӘпҒҚйҠқпҡҳоңҢ?ж№”иҝЁж’…зҘҶВҖеҗӯr\n                    }\r\n                }\r\n            }\r\n        })\r\n\r\n        // ?пӢӘ?йҠөо®Һ??оЎјжғң?иҲӘ??еҗӯr\n        if (map.getLayer('satellite-layer')) {\r\n            map.setLayoutProperty('satellite-layer', 'visibility', isSatellite ? 'visible' : 'none')\r\n        }\r\n    }, [])\r\n\r\n    // з’…вҲӘ??пӢӘ??оҝҷоӯң?е•Ј?ж’…д№Ҳr\n    useEffect(() => {\r\n        if (mapLoaded) {\r\n            updateLayerVisibility(mapMode === 'satellite')\r\n        }\r\n    }, [mapMode, mapLoaded, updateLayerVisibility])\r\n\r\n    // ?иҠё?иқ®ж јоңӣ?е”і??пҗ§? (?иҠёоҜӯ?оіҲжҙ»й ӣпҗЈп…Ҝ?оҝҳо·“йҠө?\r\n    const hasInitialized = useRef(false)\r\n\r\n    const fitBounds = useCallback(() => {\r\n        if (markers.length === 0 || !mapRef.current || !mapLoaded) return\r\n        if (hasInitialized.current) return  // ?? ?иҠёо·“йҠөп—№?з”Ҳп№Ҹr\n\r\n        hasInitialized.current = true\r\n\r\n        if (markers.length === 1) {\r\n            mapRef.current.flyTo({\r\n                center: [markers[0].lng, markers[0].lat],\r\n                zoom: 15\r\n            })\r\n            return\r\n        }\r\n\r\n        const lngs = markers.map(m => m.lng)\r\n        const lats = markers.map(m => m.lat)\r\n        const bounds: LngLatBoundsLike = [\r\n            [Math.min(...lngs), Math.min(...lats)],\r\n            [Math.max(...lngs), Math.max(...lats)]\r\n        ]\r\n\r\n        mapRef.current.fitBounds(bounds, { padding: 60, duration: 500 })\r\n    }, [markers, mapLoaded])\r\n\r\n    useEffect(() => {\r\n        const timer = setTimeout(fitBounds, 100)\r\n        return () => clearTimeout(timer)\r\n    }, [fitBounds])\r\n\r\n    // ?? ?е•Ј?й ӣпҗЈп…Ҝж•әп—»жә¶?оәЎ??оёҒ?ж’…д№Ҳr\n    const handleMapLoad = useCallback(() => {\r\n        setMapLoaded(true)\r\n\r\n        const map = mapRef.current?.getMap()\r\n        if (!map) return\r\n\r\n        // ?? ?оҹЎ?иқ»з®Ҹд»ғ?п„’?з’…о©қ??о°®??иёө??з®ҮеҫҒ?оЎҫ?еҡ—п—ҫој•??console ?иҲӘзӮҠеҡ—пҺјr\n        map.on('styleimagemissing', (e) => {\r\n            const id = e.id\r\n            // ж’ұз®Ү? 1x1 ?оҗІ??оЎҫ?йӣҝо°¬оҫӯ fallback\r\n            if (!map.hasImage(id)) {\r\n                map.addImage(id, { width: 1, height: 1, data: new Uint8Array([0, 0, 0, 0]) })\r\n            }\r\n        })\r\n\r\n        // зҳӣйӨғ? Esri йҠөо®Һ? Source\r\n        if (!map.getSource('satellite')) {\r\n            map.addSource('satellite', {\r\n                type: 'raster',\r\n                tiles: [MAP_STYLES.SATELLITE],\r\n                tileSize: 256,\r\n                attribution: 'з©ў Esri'\r\n            })\r\n        }\r\n\r\n        // зҳӣйӨғ?йҠөо®Һ??оЎјжғң (?ВҖж‘Ёоҹҹжғңеҡ—п—ҫ?й–®еүқоӘј??\r\n        if (!map.getLayer('satellite-layer')) {\r\n            const firstLayerId = map.getStyle()?.layers?.[0]?.id\r\n            map.addLayer({\r\n                id: 'satellite-layer',\r\n                type: 'raster',\r\n                source: 'satellite',\r\n                layout: { visibility: 'none' },\r\n                paint: { 'raster-opacity': 1 }\r\n            }, firstLayerId)\r\n        }\r\n\r\n        // ?? 3D ж’ұз®Ү?ж’…?(OpenMapTiles Schema)\r\n        if (!map.getLayer('3d-buildings')) {\r\n            // ?жӣүпҠҫ?пӢ©?з’…о©•жғңж’…ж–Ө? ID (иқЈз®”? 3D ж’ұз®Ү??оҳҲоҜӯ?пӢ©?йҠқп•ЎоІ„)\r\n            const layers = map.getStyle()?.layers || []\r\n            const labelLayerId = layers.find(\r\n                (layer) => layer.type === 'symbol' && 'layout' in layer && layer.layout?.['text-field']\r\n            )?.id\r\n\r\n            map.addLayer({\r\n                id: '3d-buildings',\r\n                source: 'openmaptiles',\r\n                'source-layer': 'building',\r\n                filter: ['==', 'extrude', 'true'],\r\n                type: 'fill-extrusion',\r\n                minzoom: MAP_STYLES.BUILDING_3D.MIN_ZOOM,\r\n                paint: {\r\n                    'fill-extrusion-color': MAP_STYLES.BUILDING_3D.COLOR,\r\n                    'fill-extrusion-height': [\r\n                        'interpolate',\r\n                        ['linear'],\r\n                        ['zoom'],\r\n                        15, 0,\r\n                        15.05, ['get', 'render_height']\r\n                    ],\r\n                    'fill-extrusion-base': [\r\n                        'interpolate',\r\n                        ['linear'],\r\n                        ['zoom'],\r\n                        15, 0,\r\n                        15.05, ['get', 'render_min_height']\r\n                    ],\r\n                    'fill-extrusion-opacity': MAP_STYLES.BUILDING_3D.OPACITY\r\n                }\r\n            }, labelLayerId)\r\n        }\r\n\r\n        // ?? POI жҡәоөҘ?йҲӯп•ңиҫЈ (Progressive Intelligence Layer 1)\r\n        map.on('click', (e) => {\r\n            // ?дәҘеІ·жҡәоөҘ?йӣҝпҡҷи”ӯ??POI ?оЎјжғң\r\n            const features = map.queryRenderedFeatures(e.point, {\r\n                layers: map.getStyle()?.layers\r\n                    ?.filter(l => l.id.includes('poi') || l.id.includes('label'))\r\n                    .map(l => l.id) || []\r\n            })\r\n\r\n            if (features.length > 0) {\r\n                const feature = features[0]\r\n                const props = feature.properties || {}\r\n                const coords = feature.geometry.type === 'Point'\r\n                    ? (feature.geometry as GeoJSON.Point).coordinates\r\n                    : [e.lngLat.lng, e.lngLat.lat]\r\n\r\n                // з‘Ҫп•қйҒЈ POI ?з®Ү?йһҲпӢӘ?\r\n                const poiData: POIBasicData = {\r\n                    name: props.name || props.name_en || '?иҠ°о·Ғ?еңҲ?',\r\n                    type: props.class || props.subclass || props.type || 'place',\r\n                    lat: coords[1] as number,\r\n                    lng: coords[0] as number,\r\n                    address: props.address || props.addr_street,\r\n                    phone: props.phone,\r\n                    website: props.website,\r\n                    opening_hours: props.opening_hours\r\n                }\r\n\r\n                setSelectedPOI(poiData)\r\n                setPoiDrawerOpen(true)\r\n            }\r\n        })\r\n\r\n        // ?? POI Hover зҡңиұў??иҠё?\r\n        const poiLayers = map.getStyle()?.layers\r\n            ?.filter(l => l.id.includes('poi') || l.id.includes('label'))\r\n            .map(l => l.id) || []\r\n\r\n        poiLayers.forEach(layerId => {\r\n            map.on('mouseenter', layerId, () => {\r\n                map.getCanvas().style.cursor = 'pointer'\r\n            })\r\n            map.on('mouseleave', layerId, () => {\r\n                map.getCanvas().style.cursor = ''\r\n            })\r\n        })\r\n    }, [])\r\n\r\n    // ?? ?е–ғиқҷзҳқоҳү?зҳЈйӨғ?йҠӢоё…пјҠиқ·з®ҸоҜө??(?иҠё??пүҢ?: зҳЈйӨғ? -> ?е—ҶоЈҷ?еңҲ? -> ?е•Ғо»№?еҶҪоЁқ)\r\n    const center = markers.length > 0\r\n        ? { longitude: markers[0].lng, latitude: markers[0].lat }\r\n        : dailyLoc\r\n            ? { longitude: dailyLoc.lng, latitude: dailyLoc.lat }\r\n            : { longitude: 120.9, latitude: 23.5 }  // ?е•Ғо»№йҠқеү–?жҡәоіҪr\n\r\n    // ?о“‘иә«иқ®ж јоңӣиқ‘пҗҘ?еҡ—о«ұ?зҳЈйӨғ???zoom 13еҡ—п—јпғҺзҳЈйӨғ???zoom 7 (жҶҝиҲҗе…§?е…ёоҸј??\r\n    const defaultZoom = markers.length > 0 || dailyLoc ? 13 : 7\r\n\r\n    return (\r\n        <div className=\"space-y-2\">\r\n            {/* йҲӯж—ҘВҖо«ұиҠӢж’ҳоҗөојҺ?пӢ©оЁ– + ж‘Ёоҹҹ??пӢӘ? */}\r\n            <div className=\"flex items-center justify-between\">\r\n                <div className=\"flex gap-1 bg-slate-100 rounded-lg p-1\">\r\n                    <button\r\n                        onClick={() => setMode('walk')}\r\n                        className={`flex items-center gap-1 px-3 py-1.5 rounded-md text-xs font-bold transition-all ${mode === 'walk' ? 'bg-white shadow text-green-600' : 'text-slate-500 hover:text-slate-700'\r\n                            }`}\r\n                    >\r\n                        <Footprints className=\"w-3.5 h-3.5\" />\r\n                        з”ҮдәҘ?\r\n                    </button>\r\n                    <button\r\n                        onClick={() => setMode('drive')}\r\n                        className={`flex items-center gap-1 px-3 py-1.5 rounded-md text-xs font-bold transition-all ${mode === 'drive' ? 'bg-white shadow text-blue-600' : 'text-slate-500 hover:text-slate-700'\r\n                            }`}\r\n                    >\r\n                        <Car className=\"w-3.5 h-3.5\" />\r\n                        ?п• ?\r\n                    </button>\r\n                    <button\r\n                        onClick={() => setMode('transit')}\r\n                        className={`flex items-center gap-1 px-3 py-1.5 rounded-md text-xs font-bold transition-all ${mode === 'transit' ? 'bg-white shadow text-amber-600' : 'text-slate-500 hover:text-slate-700'\r\n                            }`}\r\n                    >\r\n                        <Bus className=\"w-3.5 h-3.5\" />\r\n                        жҶӯжҠ’о°ғ?п• ж’“\r\n                    </button>\r\n                </div>\r\n\r\n                {/* ?? ж‘Ёоҹҹ??пӢӘ??пҗ§? */}\r\n                <div className=\"flex items-center gap-2\">\r\n                    {routeInfo && (\r\n                        <div className=\"flex items-center gap-3 text-xs\">\r\n                            <span className=\"text-slate-500\">?? {routeInfo.distance}</span>\r\n                            <span className=\"text-slate-500\">?жў§? {routeInfo.duration}</span>\r\n                            {loading && <span className=\"text-amber-500 animate-pulse\">й ӣпҗЈп…ҜйҠқ?..</span>}\r\n                        </div>\r\n                    )}\r\n                    <button\r\n                        onClick={() => setMapMode(m => m === 'standard' ? 'satellite' : 'standard')}\r\n                        className={`flex items-center gap-1 px-2.5 py-1.5 rounded-lg text-xs font-bold transition-all border ${mapMode === 'satellite'\r\n                            ? 'bg-blue-600 text-white border-blue-600'\r\n                            : 'bg-white text-slate-600 border-slate-200 hover:border-blue-300'\r\n                            }`}\r\n                        title={mapMode === 'satellite' ? '?пӢӘ??е”і?зҡһоЎјоҜө?? : '?пӢӘ??е•—??оёҒ?'}\r\n                    >\r\n                        {mapMode === 'satellite' ? (\r\n                            <><MapIcon className=\"w-3.5 h-3.5\" /> з’…о©”?</>\r\n                        ) : (\r\n                            <><Satellite className=\"w-3.5 h-3.5\" /> йҠөо®Һ?</>\r\n                        )}\r\n                    </button>\r\n                </div>\r\n            </div>\r\n\r\n            {/* ?е•Ј?ж‘°еӯөоЁ– - ?еҲ»?иқөжЎғзөһйҠқВҖ?оәһд№Ӣ h-[480px]еҡ—п—ҫоҰғз”ҮпјёпҷӨ?оҹҹеғ•??+ зҳЁпҺҠоЁ’?пӢ©? */}\r\n            <div className=\"rounded-xl overflow-hidden border border-slate-200 shadow-sm h-[480px] w-full z-0 relative touch-none overscroll-none\">\r\n                {/* ?? ?о°Ә??пҗ§? (ж’Ңиҷ«?й–«? */}\r\n                <button\r\n                    onClick={() => setIsSearchOpen(true)}\r\n                    className=\"absolute bottom-2 left-2 z-10 bg-white/90 backdrop-blur-md rounded-lg p-3 shadow-md hover:bg-white transition-all\"\r\n                    title=\"?о°Ә??еңҲ?\"\r\n                >\r\n                    <Search className=\"w-5 h-5 text-slate-600\" />\r\n                </button>\r\n\r\n                {/* ?? ?о°Ә? Overlay (ж‘ЁоҹЈпҖёж’…оҹЈ?) */}\r\n                <AnimatePresence>\r\n                    {isSearchOpen && (\r\n                        <motion.div\r\n                            initial={{ y: \"100%\" }}\r\n                            animate={{ y: 0 }}\r\n                            exit={{ y: \"100%\" }}\r\n                            transition={{ type: \"spring\", damping: 25, stiffness: 300 }}\r\n                            className=\"absolute inset-x-0 bottom-0 z-20 bg-white rounded-t-2xl shadow-2xl flex flex-col\"\r\n                            style={{ height: isSearchMinimized ? \"auto\" : \"85%\" }}\r\n                        >\r\n                            {/* ?? ?оЎҪоӯӣ?п•һ? + ?ВҖж’ оҗұ??пӢӘ? */}\r\n                            <button\r\n                                onClick={() => setIsSearchMinimized(!isSearchMinimized)}\r\n                                className=\"w-full py-3 flex justify-center items-center gap-2 hover:bg-slate-100 transition-colors cursor-pointer group\"\r\n                                title={isSearchMinimized ? \"ж’…оҹЈ??о°Ә?иқҜо“Ҹ?\" : \"?е—үзөІ?о°Ә?иқҜо“Ҹ?\"}\r\n                            >\r\n                                <div className=\"w-12 h-1.5 bg-slate-300 rounded-full group-hover:bg-slate-400 transition-colors\" />\r\n                                <span className=\"text-xs text-slate-400 group-hover:text-slate-600 transition-colors\">\r\n                                    {isSearchMinimized ? \"??ж’…оҹЈ?\" : \"???е—үзөІ\"}\r\n                                </span>\r\n                            </button>\r\n                            {/* ?о°Ә?й ӣи©Ёп…Ҝ?ВҖ */}\r\n                            <div className=\"p-4 border-b shrink-0 flex gap-2\">\r\n                                <div className=\"relative flex-1\">\r\n                                    <Search className=\"absolute left-3 top-2.5 w-4 h-4 text-slate-400\" />\r\n                                    <Input\r\n                                        ref={inputRef}\r\n                                        value={query}\r\n                                        onChange={handleQueryChange}\r\n                                        placeholder=\"?о°Ә??еңҲ?...\"\r\n                                        className=\"h-9 pl-9 pr-8 text-base shadow-none border-slate-200 focus-visible:ring-1\"\r\n                                        onFocus={() => setIsSearchMinimized(false)}\r\n                                    />\r\n                                    {query && (\r\n                                        <button\r\n                                            onClick={() => {\r\n                                                setQuery(\"\")\r\n                                                setIsTyping(false)\r\n                                                setResults([])\r\n                                            }}\r\n                                            className=\"absolute right-2 top-2.5 text-slate-400\"\r\n                                        >\r\n                                            <X className=\"w-4 h-4\" />\r\n                                        </button>\r\n                                    )}\r\n                                </div>\r\n                                <button\r\n                                    onClick={() => { setIsSearchOpen(false); setIsSearchMinimized(false); }}\r\n                                    className=\"px-2 text-sm text-slate-500 font-medium\"\r\n                                >\r\n                                    ?оЎҪ?\r\n                                </button>\r\n                            </div>\r\n\r\n                            {/* иқҜо“Ҹ??оӨңвҖқ (?иҲҖйҒқ?оҹ©??и„«иҝ«????и„Ј?) */}\r\n                            {!isSearchMinimized && (\r\n                                <div className=\"flex-1 overflow-y-auto overscroll-contain touch-pan-y\">\r\n                                    {/* з”Үз‘•оҸҫ */}\r\n                                    {query.length === 0 && history.length > 0 && (\r\n                                        <>\r\n                                            <div className=\"px-4 py-2 text-xs font-medium text-slate-400 uppercase bg-slate-50/50 flex justify-between items-center\">\r\n                                                <span>?ВҖйӨҲо•¬?ж’ ?/span>\r\n                                                <button\r\n                                                    onClick={(e) => {\r\n                                                        e.stopPropagation()\r\n                                                        if (confirm(\"иқЈз®Ҹ?й–¬ојј??ж–—??пҗӨ?ж’ п•ҹ??п„’?еҡ—о¶ҡ")) {\r\n                                                            clearHistory()\r\n                                                        }\r\n                                                    }}\r\n                                                    className=\"flex items-center gap-1 hover:text-red-500 transition-colors\"\r\n                                                    title=\"зҡңпҶіоЁ’иққВҖ?пӮ«"\r\n                                                >\r\n                                                    <Trash className=\"w-3 h-3\" />\r\n                                                    <span>зҡңпҶіоЁ’</span>\r\n                                                </button>\r\n                                            </div>\r\n                                            {history.map((h, i) => (\r\n                                                <button\r\n                                                    key={i}\r\n                                                    onClick={() => flyTo(h)}\r\n                                                    className=\"w-full px-4 py-3 text-left hover:bg-slate-50 flex items-center gap-3 border-b border-slate-50\"\r\n                                                >\r\n                                                    <Clock className=\"w-4 h-4 text-slate-400\" />\r\n                                                    <span className=\"text-sm line-clamp-1\">{h.name}</span>\r\n                                                </button>\r\n                                            ))}\r\n                                        </>\r\n                                    )}\r\n\r\n                                    {/* ?? й ӣи©Ёп…ҜйҠқе“Ё?debounce ?оё…?еҡ—? зҳӣвҲҹпҸ°?о“җе…§ */}\r\n                                    {isTyping && !isSearching && (\r\n                                        <div className=\"px-4 py-4 flex items-center gap-2 text-slate-400\">\r\n                                            <div className=\"w-1.5 h-1.5 bg-slate-300 rounded-full animate-pulse\" />\r\n                                            <span className=\"text-sm\">иқ‘пҗЈ?й ӣи©Ёп…Ҝж‘°п—»?...</span>\r\n                                        </div>\r\n                                    )}\r\n\r\n                                    {/* ?о°Ә?йҠқе“Ё?API йҡӨиј»оң…йҠқе“Ё?- Loading */}\r\n                                    {isSearching && (\r\n                                        <div className=\"px-4 py-6 flex items-center justify-center gap-2 text-indigo-500\">\r\n                                            <Loader2 className=\"w-4 h-4 animate-spin\" />\r\n                                            <span className=\"text-sm\">?о°Ә?йҠқ?..</span>\r\n                                        </div>\r\n                                    )}\r\n\r\n                                    {/* ?? иқҜжӣ№??о°Ә?ж‘°п—»??ВҖ??*/}\r\n                                    {(() => {\r\n                                        const searchDone = query.length >= 2 && !isTyping && !isSearching\r\n                                        const hasResults = results.length > 0\r\n                                        const noResults = results.length === 0\r\n\r\n                                        return (\r\n                                            <>\r\n                                                {/* иқҜо“Ҹ? */}\r\n                                                {searchDone && hasResults && results.map((r, i) => (\r\n                                                    <button\r\n                                                        key={i}\r\n                                                        onClick={() => flyTo(r)}\r\n                                                        className=\"w-full px-4 py-3 text-left hover:bg-slate-50 flex items-start gap-3 border-b border-slate-50\"\r\n                                                    >\r\n                                                        <MapPin className=\"w-4 h-4 mt-0.5 text-slate-400 shrink-0\" />\r\n                                                        <div className=\"min-w-0\">\r\n                                                            <div className=\"text-sm font-medium truncate\">{r.name}</div>\r\n                                                            {r.address && <div className=\"text-xs text-slate-500 truncate\">{r.address}</div>}\r\n                                                        </div>\r\n                                                    </button>\r\n                                                ))}\r\n\r\n                                                {/* ?вҲ ??о°«?иқ·?*/}\r\n                                                {searchDone && noResults && (\r\n                                                    <div className=\"px-4 py-4 text-center text-slate-500 text-sm\">\r\n                                                        ?жӣҶ??е•ңВҖп–Іquery}?пҡҷ?иқҜо“Ҹ?\r\n                                                    </div>\r\n                                                )}\r\n\r\n                                                {/* AI ?иіҠ? - ?жҖҘ??жўҜ?еҡ—п—№??о©•?ж’ҳоҗів…Јйқҳо®ҺоҜҜйқҳпүҗ???*/}\r\n                                                {/* {searchDone && (\r\n                                                    <button\r\n                                                        onClick={handleAISearch}\r\n                                                        disabled={aiSearching}\r\n                                                        className=\"w-full px-4 py-4 text-left hover:bg-purple-50 flex items-center gap-3 text-sm border-t border-slate-100\"\r\n                                                    >\r\n                                                        {aiSearching ? (\r\n                                                            <>\r\n                                                                <Loader2 className=\"w-4 h-4 text-purple-500 animate-spin\" />\r\n                                                                <span className=\"text-purple-600\">з”Ү?оҜӯй–°пј·? AI...</span>\r\n                                                            </>\r\n                                                        ) : (\r\n                                                            <>\r\n                                                                <Sparkles className=\"w-4 h-4 text-purple-500\" />\r\n                                                                <span className=\"text-purple-600 font-medium\">??йӣҝиј»оң… AI ?о°Ә??п–Іquery}??/span>\r\n                                                            </>\r\n                                                        )}\r\n                                                    </button>\r\n                                                )} */}\r\n                                            </>\r\n                                        )\r\n                                    })()}\r\n                                </div>\r\n                            )}\r\n                        </motion.div>\r\n                    )}\r\n                </AnimatePresence>\r\n                <Map\r\n                    ref={mapRef}\r\n                    reuseMaps={true}\r\n                    initialViewState={{\r\n                        longitude: center.longitude,\r\n                        latitude: center.latitude,\r\n                        zoom: defaultZoom\r\n                    }}\r\n                    style={{ width: \"100%\", height: \"100%\" }}\r\n                    mapStyle={MAP_STYLES.VECTOR}\r\n                    onLoad={handleMapLoad}\r\n                    attributionControl={false}\r\n                    minZoom={3}\r\n                    maxZoom={20}\r\n                >\r\n                    {/* ?? ?иҠё?иқўжӢҷ?йӣҝпҡҳ???(?оЎ»иӘЁ??bug ??GeolocateControl) */}\r\n                    <button\r\n                        onClick={handleLocateMe}\r\n                        disabled={isLocating}\r\n                        className=\"absolute top-28 right-2 z-10 p-2 bg-white rounded-lg shadow-md hover:bg-gray-50 disabled:opacity-50 transition-all\"\r\n                        title=\"ж‘°о«Ҝ??о•ӯ?йӣҝпҡҷи”ӯ\"\r\n                    >\r\n                        {isLocating ? (\r\n                            <Loader2 className=\"w-5 h-5 animate-spin text-blue-500\" />\r\n                        ) : (\r\n                            <Crosshair className=\"w-5 h-5 text-gray-600\" />\r\n                        )}\r\n                    </button>\r\n                    <NavigationControl position=\"top-right\" showCompass={true} />\r\n                    <AttributionControl\r\n                        customAttribution=\"з©ў OpenStreetMap з№ҡ з©ў OpenFreeMap з№ҡ з©ў Esri\"\r\n                        position=\"bottom-right\"\r\n                        compact={true}\r\n                    />\r\n\r\n                    {/* ?? ?еҶҪпҚ—йӣҝпҡҷи”ӯ?пҡӣ?з’…о©–? */}\r\n                    {userLocation && (\r\n                        <Marker\r\n                            longitude={userLocation.lng}\r\n                            latitude={userLocation.lat}\r\n                            anchor=\"center\"\r\n                        >\r\n                            <div className=\"relative\">\r\n                                {/* жҶӯоЎјжғң?пҺҶ???*/}\r\n                                <div className=\"absolute -inset-3 bg-blue-400/30 rounded-full animate-ping\" />\r\n                                {/* ?пҡӣ? */}\r\n                                <div className=\"w-4 h-4 bg-blue-500 border-2 border-white rounded-full shadow-lg\" />\r\n                            </div>\r\n                        </Marker>\r\n                    )}\r\n\r\n                    {/* й қиҲҗ?иқңиҠҫЛҠ */}\r\n                    {route && (\r\n                        <Source id=\"route\" type=\"geojson\" data={route}>\r\n                            <Layer\r\n                                id=\"route-line\"\r\n                                type=\"line\"\r\n                                paint={{\r\n                                    \"line-color\": routeInfo?.source === 'straight-line' ? '#94a3b8' : routeColors[mode],\r\n                                    \"line-width\": routeInfo?.source === 'straight-line' ? 3 : 5,\r\n                                    \"line-opacity\": routeInfo?.source === 'straight-line' ? 0.6 : 0.8,\r\n                                    \"line-dasharray\": routeInfo?.source === 'straight-line' || mode === 'transit' ? [2, 2] : [1, 0]\r\n                                }}\r\n                            />\r\n                        </Source>\r\n                    )}\r\n\r\n                    {/* з’…о©–?жҡә?*/}\r\n                    {markers.map((m, idx) => {\r\n                        const isFirst = idx === 0\r\n                        const isLast = idx === markers.length - 1\r\n                        const color = isFirst ? \"#22c55e\" : isLast ? \"#ef4444\" : \"#0f172a\"\r\n\r\n                        return (\r\n                            <Marker\r\n                                key={m.id || `marker-${idx}`}\r\n                                longitude={m.lng}\r\n                                latitude={m.lat}\r\n                                anchor=\"center\"\r\n                                onClick={(e) => {\r\n                                    e.originalEvent.stopPropagation()\r\n                                    setPopupInfo(m)\r\n                                }}\r\n                            >\r\n                                <div\r\n                                    style={{\r\n                                        backgroundColor: color,\r\n                                        color: \"white\",\r\n                                        width: 28,\r\n                                        height: 28,\r\n                                        borderRadius: \"50%\",\r\n                                        display: \"flex\",\r\n                                        alignItems: \"center\",\r\n                                        justifyContent: \"center\",\r\n                                        fontWeight: \"bold\",\r\n                                        border: \"3px solid white\",\r\n                                        boxShadow: \"0 2px 8px rgba(0,0,0,0.3)\",\r\n                                        fontSize: 12,\r\n                                        cursor: \"pointer\"\r\n                                    }}\r\n                                >\r\n                                    {m.number}\r\n                                </div>\r\n                            </Marker>\r\n                        )\r\n                    })}\r\n\r\n                    {/* ?? ?о°Ә?иқҜо“Ҹ?з’…о©–?еҡ—пҺҲ??и„Јд№Ӣ?еүқ?еҡ—?*/}\r\n                    {searchResultMarker && (\r\n                        <Marker\r\n                            longitude={searchResultMarker.lng}\r\n                            latitude={searchResultMarker.lat}\r\n                            anchor=\"bottom\"\r\n                        >\r\n                            <div className=\"relative animate-bounce\" style={{ animationDuration: '0.6s', animationIterationCount: 3 }}>\r\n                                {/* ?е•Ји”Ј */}\r\n                                <div\r\n                                    className=\"absolute -bottom-1 left-1/2 -translate-x-1/2 w-4 h-1 bg-black/30 rounded-full blur-sm\"\r\n                                />\r\n                                {/* жҶӯжҠҳо№Ұ??*/}\r\n                                <div className=\"relative\">\r\n                                    {/* ?оіӢ? */}\r\n                                    <div\r\n                                        className=\"w-8 h-8 bg-red-500 rounded-full border-3 border-white shadow-lg flex items-center justify-center\"\r\n                                        style={{\r\n                                            boxShadow: '0 4px 12px rgba(239, 68, 68, 0.5), 0 2px 4px rgba(0,0,0,0.2)'\r\n                                        }}\r\n                                    >\r\n                                        <div className=\"w-2 h-2 bg-white rounded-full\" />\r\n                                    </div>\r\n                                    {/* ?оіҮ? */}\r\n                                    <div\r\n                                        className=\"absolute left-1/2 -translate-x-1/2 w-0 h-0\"\r\n                                        style={{\r\n                                            borderLeft: '6px solid transparent',\r\n                                            borderRight: '6px solid transparent',\r\n                                            borderTop: '10px solid #ef4444',\r\n                                            top: '26px'\r\n                                        }}\r\n                                    />\r\n                                </div>\r\n                            </div>\r\n                        </Marker>\r\n                    )}\r\n\r\n\r\n                    {/* ж•¶пҺҶпҠҫй–¬оЎҫ? */}\r\n                    {popupInfo && (\r\n                        <Popup\r\n                            longitude={popupInfo.lng}\r\n                            latitude={popupInfo.lat}\r\n                            anchor=\"bottom\"\r\n                            onClose={() => setPopupInfo(null)}\r\n                            closeOnClick={false}\r\n                        >\r\n                            <div className=\"min-w-[150px] p-1\">\r\n                                <div className=\"font-bold text-sm\">{popupInfo.number}. {popupInfo.place}</div>\r\n                                {popupInfo.time && <div className=\"text-xs text-slate-500 mt-1\">?? {popupInfo.time}</div>}\r\n                                {popupInfo.desc && <div className=\"text-xs text-slate-600 mt-1\">{popupInfo.desc}</div>}\r\n                                <a\r\n                                    href={`https://www.google.com/maps/dir/?api=1&destination=${popupInfo.lat},${popupInfo.lng}`}\r\n                                    target=\"_blank\"\r\n                                    rel=\"noopener noreferrer\"\r\n                                    className=\"block mt-2 text-xs text-blue-500 hover:underline\"\r\n                                >\r\n                                    ?? ??Google Maps ?п•қ?ж’ оҺ—пҚӢ\r\n                                </a>\r\n                            </div>\r\n                        </Popup>\r\n                    )}\r\n                </Map>\r\n            </div>\r\n\r\n            {/* ?оЎ»? */}\r\n            <div className=\"flex items-center justify-center gap-4 text-[10px] text-slate-400\">\r\n                <span className=\"flex items-center gap-1\"><span className=\"w-2.5 h-2.5 rounded-full bg-green-500\"></span> йҹҸзҗҝ?</span>\r\n                <span className=\"flex items-center gap-1\"><span className=\"w-2.5 h-2.5 rounded-full bg-slate-800\"></span> ?оқ„?</span>\r\n                <span className=\"flex items-center gap-1\"><span className=\"w-2.5 h-2.5 rounded-full bg-red-500\"></span> иқҜоҝң?</span>\r\n                {mapMode === 'satellite' && <span className=\"flex items-center gap-1\">?оӯҳе„ӯ?йҠөо®Һ?з’…вҲӘ?</span>}\r\n            </div>\r\n\r\n\r\n\r\n            {/* ?? POI Detail Drawer (Progressive Intelligence) */}\r\n            <POIDetailDrawer\r\n                isOpen={poiDrawerOpen}\r\n                onClose={() => setPoiDrawerOpen(false)}\r\n                poi={selectedPOI}\r\n                suggestedTime={(() => {\r\n                    // ?з®ёп…ұ?оҝң?й–®пҺҲ?еҡ—о«ұ?ж•әп—»жҡ‘??+1.5 ж’ оҗІ?\r\n                    if (activities.length > 0) {\r\n                        const lastActivity = activities[activities.length - 1]\r\n                        if (lastActivity.time) {\r\n                            const [h, m] = lastActivity.time.split(\":\").map(Number)\r\n                            const totalMinutes = h * 60 + m + 90\r\n                            const newH = Math.min(23, Math.floor(totalMinutes / 60))\r\n                            const newM = totalMinutes % 60\r\n                            return `${newH.toString().padStart(2, \"0\")}:${newM.toString().padStart(2, \"0\")}`\r\n                        }\r\n                    }\r\n                    return \"10:00\"\r\n                })()}\r\n                onAddToItinerary={(poi, time, aiSummary) => {\r\n                    // йҡӨиј»оң…?е—…жғң callback\r\n                    if (onAddPOI) {\r\n                        const notes = aiSummary\r\n                            ? `${aiSummary.summary}\\nж•№пҶі?: ${aiSummary.must_try?.join(', ') || ''}`\r\n                            : undefined\r\n                        onAddPOI(poi, time, notes)\r\n                    } else {\r\n                        console.log('?? Add to itinerary:', poi, time)\r\n                        if (aiSummary) {\r\n                            console.log('?? AI Summary:', aiSummary)\r\n                        }\r\n                    }\r\n                    // ?? зҡңпҶіоЁ’?о°Ә?з’…о©–?\r\n                    setSearchResultMarker(null)\r\n                }}\r\n            />\r\n        </div>\r\n    )\